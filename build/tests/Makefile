	cd /home/edwab/ws-camera-d/build && $(MAKE) $(MAKESILENT) -f tests/CMakeFiles/camera_daemon_tests.dir/build.make tests/CMakeFiles/camera_daemon_tests.dir/test_v4l2_loopback.cpp.i
.PHONY : test_v4l2_loopback.cpp.i

test_v4l2_loopback.s: test_v4l2_loopback.cpp.s
.PHONY : test_v4l2_loopback.s

# target to generate assembly for a file
test_v4l2_loopback.cpp.s:
	cd /home/edwab/ws-camera-d/build && $(MAKE) $(MAKESILENT) -f tests/CMakeFiles/camera_daemon_tests.dir/build.make tests/CMakeFiles/camera_daemon_tests.dir/test_v4l2_loopback.cpp.s
.PHONY : test_v4l2_loopback.cpp.s

